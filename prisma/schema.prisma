generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id         String   @id @default(cuid()) @db.VarChar(30)
  googleSub  String   @unique @map("google_sub") @db.VarChar(64)
  email      String   @unique @db.VarChar(255)
  name       String   @db.VarChar(255)
  pictureUrl String?  @map("picture_url") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  userCourses  UserCourse[]
  authSessions AuthSession[]

  @@map("users")
}

model Course {
  id      String  @id @db.VarChar(30)
  code    String  @unique @db.VarChar(32)
  titleTh String  @map("title_th") @db.VarChar(255)
  titleEn String? @map("title_en") @db.VarChar(255)

  offerings CourseOffering[]

  @@map("courses")
}

model CourseOffering {
  id          String  @id @default(cuid()) @db.VarChar(30)
  courseId    String  @map("course_id")
  section     String  @db.VarChar(32)
  instructor  String? @db.VarChar(255)
  sectionType String? @map("section_type") @db.VarChar(32)
  credits     Decimal @default(3.0) @db.Decimal(4, 1)

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userCourses UserCourse[]
  exams       Exam[]

  @@unique([courseId, section], map: "uq_offering_course_section")
  @@map("course_offerings")
}

model UserCourse {
  userId     String   @map("user_id")
  offeringId String   @map("offering_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  offering CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@id([userId, offeringId])
  @@index([offeringId], map: "idx_user_courses_offering")
  @@map("user_courses")
}

model Exam {
  id         String   @id @default(cuid()) @db.VarChar(30)
  offeringId String   @map("offering_id")
  examType   String   @map("exam_type") @db.VarChar(16)
  examDate   DateTime @map("exam_date") @db.Date
  startTime  DateTime @map("start_time") @db.Time
  endTime    DateTime @map("end_time") @db.Time
  building   String?  @db.VarChar(255)
  room       String?  @db.VarChar(255)
  note       String?  @db.Text
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  offering CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@index([examDate], map: "idx_exam_date")
  @@index([offeringId], map: "idx_exam_offering")
  @@map("exams")
}

model AuthSession {
  id        String    @id @default(cuid()) @db.VarChar(30)
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId], map: "idx_sessions_user")
  @@index([revokedAt], map: "idx_sessions_revoked")
  @@map("auth_sessions")
}

model RefreshToken {
  id        String    @id @default(cuid()) @db.VarChar(30)
  sessionId String    @map("session_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  session AuthSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId], map: "idx_refresh_session")
  @@index([expiresAt], map: "idx_refresh_expires")
  @@index([revokedAt], map: "idx_refresh_revoked")
  @@map("refresh_tokens")
}
