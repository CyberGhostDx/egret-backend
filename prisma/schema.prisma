generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String   @id @default(cuid()) @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  name          String   @db.VarChar(255)
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  sessions    Session[]
  accounts    Account[]
  userCourses UserCourse[]

  @@map("users")
}

model Course {
  id      String  @id @db.VarChar(30)
  code    String  @unique @db.VarChar(32)
  titleTh String  @map("title_th") @db.VarChar(255)
  titleEn String? @map("title_en") @db.VarChar(255)

  offerings CourseOffering[]

  @@map("courses")
}

model CourseOffering {
  id          String  @id @default(cuid()) @db.VarChar(30)
  courseId    String  @map("course_id") @db.VarChar(30)
  section     String  @db.VarChar(32)
  instructor  String? @db.VarChar(255)
  sectionType String? @map("section_type") @db.VarChar(32)
  credits     Decimal @default(3.0) @db.Decimal(4, 1)

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userCourses UserCourse[]
  exams       Exam[]

  @@unique([courseId, section], map: "uq_offering_course_section")
  @@map("course_offerings")
}

model UserCourse {
  userId     String   @map("user_id") @db.VarChar(255)
  offeringId String   @map("offering_id") @db.VarChar(30)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  offering CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@id([userId, offeringId])
  @@index([offeringId], map: "idx_user_courses_offering")
  @@map("user_courses")
}

model Exam {
  id         String   @id @default(cuid()) @db.VarChar(30)
  offeringId String   @map("offering_id") @db.VarChar(30)
  examType   String   @map("exam_type") @db.VarChar(16)
  examDate   DateTime @map("exam_date") @db.Date
  startTime  DateTime @map("start_time") @db.Time
  endTime    DateTime @map("end_time") @db.Time
  building   String?  @db.VarChar(255)
  room       String?  @db.VarChar(255)
  note       String?  @db.Text
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  offering CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@index([examDate], map: "idx_exam_date")
  @@index([offeringId], map: "idx_exam_offering")
  @@map("exams")
}

model Session {
  id        String   @id @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  token     String   @unique @db.VarChar(255)
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address") @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.Text
  userId    String   @map("user_id") @db.VarChar(255)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @db.VarChar(255)
  accountId             String    @map("account_id") @db.VarChar(255)
  providerId            String    @map("provider_id") @db.VarChar(255)
  userId                String    @map("user_id") @db.VarChar(255)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.Text
  password              String?   @db.VarChar(255)
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")

  @@map("account")
}

model Verification {
  id         String    @id @db.VarChar(255)
  identifier String    @db.VarChar(255)
  value      String    @db.Text
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verification")
}
